# Flask Configuration
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production

# Database Configuration
DATABASE_URL=postgresql://hawkeroute:hawkeroute@localhost:5432/hawkeroute

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Configuration (update with your email service details)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# JWT Configuration
JWT_SECRET_KEY=another-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600  # 1 hour

# API Rate Limiting
RATELIMIT_DEFAULT=100/hour
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# Push Notifications (if using Firebase)
FIREBASE_CREDENTIALS=path/to/firebase-credentials.json

# SMS Configuration (if using Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=your-twilio-number

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Google Maps
GOOGLE_MAPS_API_KEY=AIzaSyAysR6uOCA_W0M9RmZPpTWffN-BsQmnL_o

# Application Settings
TIMEZONE=Asia/India  # For order cutoff time calculations

# SocketIO configuration
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO 